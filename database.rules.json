{
  "rules": {
    "users": {
        "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid",
            "profile": {
                ".validate": "newData.hasChildren(['role', 'name'])"
            }
        }
    },
    "sessions": {
        "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['lastActive', 'ownerId'])"
        }
    },
    "patients": {
        "$ownerId": {
            ".read": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".write": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".indexOn": ["createdAt", "mobile", "name", "patientId"],
            "$patientId": {
                // Allow reading specific patient details for PDF generation if user is authenticated (link protection)
                ".read": "auth != null"
            }
        }
    },
    "reports": {
        "$ownerId": {
            ".read": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".write": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".indexOn": ["createdAt", "patientId", "date", "status", "billNumber"],
            "$reportId": {
                // Allow viewing specific report if direct link is known
                ".read": "auth != null"
            }
        }
    },
    "samples": {
        "$ownerId": {
            ".read": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".write": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".indexOn": ["status", "patientId", "date", "createdAt"]
        }
    },
    "doctors": {
        "$ownerId": {
            ".read": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".write": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".indexOn": ["name", "email", "createdAt"]
        }
    },
    "externalDoctors": {
        "$ownerId": {
            ".read": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".write": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)"
        }
    },
    "templates": {
        "$ownerId": {
            ".read": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".write": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)"
        }
    },
    "counters": {
        "$ownerId": {
            ".read": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".write": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)"
        }
    },
    "subscriptions": {
        "$ownerId": {
            // Needed for system features and layout logic
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $ownerId"
        }
    },
    "audit_logs": {
        "$ownerId": {
            ".read": "auth != null && (auth.uid === $ownerId || root.child('sessions').child(auth.uid).child('ownerId').val() === $ownerId)",
            ".write": "auth != null"
        }
    },
    "payment_requests": {
        "$ownerId": {
            ".read": "auth != null && auth.uid === $ownerId",
            ".write": "auth != null && auth.uid === $ownerId"
        }
    },
    "branding": {
        "$ownerId": {
            // Lab logo/address must be public for PDF generation
            ".read": "true",
            ".write": "auth != null && auth.uid === $ownerId"
        }
    },
    "common_templates": {
        ".read": "true",
        ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'"
    }
  }
}